// packages/shared/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Gestion des Tenants (Groupes scolaires / Écoles isolées)
model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        Plan     @default(FREE)
  config      Json?    // Configuration spécifique du tenant (logos, couleurs, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  schools     School[]
  users       User[]

  @@index([slug, deletedAt])
  @@map("tenants")
}

enum Plan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

// 2. Écoles (Une école appartient à un tenant)
model School {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  type        SchoolType
  address     String?
  config      Json?    // Configuration spécifique à l'école (emploi du temps, règlements)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  classes     Class[]
  staff       Staff[]
  students    Student[]
  subjects    Subject[]

  @@index([tenantId, deletedAt])
  @@map("schools")
}

enum SchoolType {
  PRIMARY
  SECONDARY
  HIGH_SCHOOL
  COMPLEX
}

// 3. Utilisateurs et IAM (RBAC)
model User {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  email         String   @unique
  password      String
  role          Role     @default(PARENT)
  permissions   String[] // Permissions granulaires
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  staffProfile  Staff?
  studentProfile Student? @relation("StudentUser")
  children      Student[] @relation("ParentToStudents")

  @@index([tenantId, deletedAt])
  @@index([email, deletedAt])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  DIRECTEUR
  ENSEIGNANT
  COMPTABLE
  PARENT
  STUDENT
}

// 4. Élèves
model Student {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  userId      String?  @unique
  user        User?    @relation("StudentUser", fields: [userId], references: [id])
  parentId    String?  // ID de l'utilisateur Parent
  parent      User?    @relation("ParentToStudents", fields: [parentId], references: [id])
  firstName   String
  lastName    String
  birthDate   DateTime
  matricule   String   @unique
  deletedAt   DateTime?
  enrollments Enrollment[]
  createdAt   DateTime @default(now())

  @@index([schoolId, deletedAt])
  @@index([matricule, deletedAt])
  @@map("students")
}

// 5. Inscriptions (Par année scolaire)
model Enrollment {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  yearId      String   // ID de l'année scolaire (ex: 2024-2025)
  status      EnrollmentStatus @default(ACTIVE)
  feesTotal   Decimal  @db.Decimal(15, 2)
  deletedAt   DateTime?
  grades      Grade[]
  payments    Payment[]
  attendance  Attendance[]
  createdAt   DateTime @default(now())

  @@index([studentId, yearId, deletedAt])
  @@index([classId, yearId, deletedAt])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  GRADUATED
}

// 6. Classes
model Class {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String
  level       String
  deletedAt   DateTime?
  enrollments Enrollment[]
  timetable   TimetableEntry[]

  @@index([schoolId, deletedAt])
  @@map("classes")
}

// 11. Matières
model Subject {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String
  code        String?
  coefficient Int      @default(1)
  deletedAt   DateTime?
  timetable   TimetableEntry[]

  @@unique([schoolId, name])
  @@index([schoolId, deletedAt])
  @@map("subjects")
}

// 12. Emploi du Temps
model TimetableEntry {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id])
  dayOfWeek   Int      // 0 (Dimanche) à 6 (Samedi)
  startTime   String   // Format HH:mm
  endTime     String   // Format HH:mm
  room        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([classId, dayOfWeek, deletedAt])
  @@index([staffId, dayOfWeek, deletedAt])
  @@map("timetable_entries")
}

// 13. Présences / Absences
model Attendance {
  id           String   @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  date         DateTime @default(now())
  status       AttendanceStatus
  reason       String?  // Justification
  reportedById String   // ID de l'enseignant qui fait l'appel
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([enrollmentId, date, deletedAt])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// 7. Notes
model Grade {
  id           String   @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  subjectId    String
  value        Decimal  @db.Decimal(5, 2)
  coeff        Int      @default(1)
  period       String   // Trimestre 1, Semestre 2, etc.
  type         String   // Devoir, Composition
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([enrollmentId, subjectId, deletedAt])
  @@map("grades")
}

// 8. Paiements
model Payment {
  id           String   @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  amount       Decimal  @db.Decimal(15, 2)
  method       PaymentMethod
  providerRef  String?  // Référence Orange Money / Wave
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([enrollmentId, status, deletedAt])
  @@map("payments")
}

enum PaymentMethod {
  ORANGE_MONEY
  WAVE
  CASH
  CHEQUE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// 9. Personnel RH
model Staff {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  role         String   // Titre du poste (Enseignant Math, Concierge, etc.)
  salary       Decimal? @db.Decimal(15, 2)
  contractType String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  timetable    TimetableEntry[]

  @@index([schoolId, deletedAt])
  @@map("staff")
}

// 10. Logs d'Audit (Sécurité)
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  deletedAt   DateTime?
  timestamp   DateTime @default(now())

  @@index([userId, timestamp])
  @@map("audit_logs")
}

// 14. Configuration Système Globale (SaaS)
model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique // ex: 'WAVE_API_KEY', 'SMS_PROVIDER_CONFIG', 'MAINTENANCE_MODE'
  value       Json     // Valeur flexible (string, number, ou objet)
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}
